// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  
}

// ─────────────────────────────────────────
// AUTH & USERS (Admin side only)
// ─────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(STAFF)
  phone        String?
  avatarUrl    String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignedEnquiries Enquiry[]     @relation("AssignedTo")
  activityLogs      ActivityLog[]
  enquiryNotes      EnquiryNote[]
  properties        Property[]    @relation("ManagedBy")
}

// ─────────────────────────────────────────
// PROPERTIES
// ─────────────────────────────────────────

enum ListingType {
  FOR_SALE
  FOR_RENT
  SHORT_LET
}

enum PropertyStatus {
  AVAILABLE
  UNDER_OFFER
  SOLD
  RENTED
  WITHDRAWN
}

model Property {
  id            String         @id @default(cuid())
  title         String
  slug          String         @unique
  description   String
  listingType   ListingType
  status        PropertyStatus @default(AVAILABLE)
  isFeatured    Boolean        @default(false)
  isPublished   Boolean        @default(false)
  publishedAt   DateTime?

  // Pricing
  salePrice     Decimal?       @db.Decimal(12, 2)
  rentPrice     Decimal?       @db.Decimal(12, 2)
  shortLetPrice Decimal?       @db.Decimal(12, 2)
  currency      String         @default("KES")

  // Location
  address       String
  city          String
  county        String?
  country       String         @default("Kenya")
  latitude      Float?
  longitude     Float?

  // Physical
  sizeValue     Float?
  sizeUnit      String?

  // ── Full-text search vector ──────────────
  // Weighted tsvector built from:
  //   A (highest): title
  //   B           : city, county, address
  //   C           : description
  //   D (lowest)  : category name, tags (denormalised into this column via trigger)
  //
  // This is a GENERATED column managed by a Postgres trigger (see migration below).
  // Prisma maps it as Unsupported so it never tries to write to it.
  searchVector  Unsupported("tsvector")?

  // Type-specific detail (only one populated)
  apartmentDetail  ApartmentDetail?
  houseDetail      HouseDetail?
  commercialDetail CommercialDetail?
  landDetail       LandDetail?

  // Relations
  images        PropertyImage[]
  amenities     PropertyAmenity[]
  tags          PropertyTag[]
  enquiries     Enquiry[]
  bookings      Booking[]
  propertyViews PropertyView[]
  category      PropertyCategory? @relation(fields: [categoryId], references: [id])
  categoryId    String?
  managedBy     User?             @relation("ManagedBy", fields: [managedById], references: [id])
  managedById   String?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // ── Indexes ──────────────────────────────
  //
  // 1. Full-text search (GIN on tsvector) — handles natural language queries
  //    e.g. "3 bedroom apartment Kilimani"
  //    Defined in migration SQL (Prisma can't declare GIN indexes on Unsupported columns)
  //
  // 2. Trigram indexes (GIN pg_trgm) on title, city, address — fuzzy / partial match
  //    e.g. user types "Kilim" and gets "Kilimani" results
  //    Also defined in migration SQL
  //
  // 3. Composite indexes for the most common filter combinations:

  @@index([isPublished, status])                          // base visibility filter on every query
  @@index([isPublished, status, listingType])             // public listing page filters
  @@index([isPublished, status, listingType, city])       // location + type filter
  @@index([isPublished, status, listingType, categoryId]) // category page (apartments, land, etc.)
  @@index([isPublished, status, salePrice])               // price range sort/filter — for sale
  @@index([isPublished, status, rentPrice])               // price range sort/filter — for rent
  @@index([isFeatured, isPublished, status])              // featured listings on homepage
  @@index([city])                                         // location browse / autocomplete
  @@index([county])                                       // county-level browse
  @@index([categoryId])
  @@index([createdAt])                                    // "newest listings" sort
  @@index([publishedAt])                                  // "recently published" sort
}

// ── Type-specific detail tables ──────────

model ApartmentDetail {
  id           String   @id @default(cuid())
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId   String   @unique
  bedrooms     Int
  bathrooms    Int
  floor        Int?
  totalFloors  Int?
  parkingSpots Int      @default(0)
  isFurnished  Boolean  @default(false)
  hasBalcony   Boolean  @default(false)
  hasGym       Boolean  @default(false)
  hasPool      Boolean  @default(false)
  hasCCTV      Boolean  @default(false)
  hasGenerator Boolean  @default(false)

  // Indexes for apartment-specific filters
  @@index([bedrooms])           // "2 bedroom" filter
  @@index([bedrooms, bathrooms])
  @@index([isFurnished])
  @@index([floor])
}

model HouseDetail {
  id           String   @id @default(cuid())
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId   String   @unique
  bedrooms     Int
  bathrooms    Int
  stories      Int      @default(1)
  parkingSpots Int      @default(0)
  isFurnished  Boolean  @default(false)
  hasGarden    Boolean  @default(false)
  hasPool      Boolean  @default(false)
  hasGate      Boolean  @default(false)
  hasGarage    Boolean  @default(false)
  hasBQ        Boolean  @default(false)

  @@index([bedrooms])
  @@index([bedrooms, bathrooms])
  @@index([isFurnished])
}

model CommercialDetail {
  id             String   @id @default(cuid())
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId     String   @unique
  commercialType String
  floor          Int?
  totalFloors    Int?
  parkingSpots   Int      @default(0)
  hasReception   Boolean  @default(false)
  hasBoardroom   Boolean  @default(false)
  hasLifts       Boolean  @default(false)
  isOpenPlan     Boolean  @default(false)
  numberOfRooms  Int?

  @@index([commercialType])
}

model LandDetail {
  id            String   @id @default(cuid())
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId    String   @unique
  landType      String
  isServiced    Boolean  @default(false)
  isFenced      Boolean  @default(false)
  hasRoadAccess Boolean  @default(true)
  titleDeedType String?

  @@index([landType])
  @@index([isServiced])
}

// ── Supporting property models ────────────

model PropertyImage {
  id         String   @id @default(cuid())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  url        String
  altText    String?
  isPrimary  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([propertyId, isPrimary]) // fast primary image lookup
}

model PropertyCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  properties  Property[]
  createdAt   DateTime   @default(now())
}

model Amenity {
  id         String            @id @default(cuid())
  name       String            @unique
  icon       String?
  properties PropertyAmenity[]
}

model PropertyAmenity {
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  amenity    Amenity  @relation(fields: [amenityId], references: [id])
  amenityId  String

  @@id([propertyId, amenityId])
}

model Tag {
  id         String        @id @default(cuid())
  name       String        @unique
  slug       String        @unique
  properties PropertyTag[]
}

model PropertyTag {
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  tag        Tag      @relation(fields: [tagId], references: [id])
  tagId      String

  @@id([propertyId, tagId])
}

// ─────────────────────────────────────────
// LEADS & ENQUIRIES
// ─────────────────────────────────────────

enum EnquiryType {
  PROPERTY_INFO
  QUOTE_REQUEST
  VIEWING_REQUEST
  GENERAL
}

enum EnquiryStatus {
  NEW
  IN_PROGRESS
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  CLOSED
}

enum EnquirySource {
  WEBSITE_MODAL
  WHATSAPP
  PHONE
  EMAIL
  WALK_IN
  REFERRAL
  SOCIAL_MEDIA
}

model Lead {
  id        String    @id @default(cuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime  @default(now())

  enquiries Enquiry[]

  @@index([email])
  @@index([phone])
}

model Enquiry {
  id           String        @id @default(cuid())
  lead         Lead          @relation(fields: [leadId], references: [id])
  leadId       String
  type         EnquiryType   @default(PROPERTY_INFO)
  message      String?
  source       EnquirySource @default(WEBSITE_MODAL)
  status       EnquiryStatus @default(NEW)
  isRead       Boolean       @default(false)

  property     Property?     @relation(fields: [propertyId], references: [id])
  propertyId   String?

  assignedTo   User?         @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedToId String?

  booking      Booking?
  notes        EnquiryNote[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@index([isRead, status])   // unread queue in admin
  @@index([leadId])
  @@index([propertyId])
  @@index([createdAt])
}

model EnquiryNote {
  id        String   @id @default(cuid())
  enquiry   Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  enquiryId String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  content   String
  createdAt DateTime @default(now())

  @@index([enquiryId])
}

// ─────────────────────────────────────────
// BOOKINGS / VIEWINGS
// ─────────────────────────────────────────

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Booking {
  id          String        @id @default(cuid())
  enquiry     Enquiry       @relation(fields: [enquiryId], references: [id])
  enquiryId   String        @unique
  property    Property      @relation(fields: [propertyId], references: [id])
  propertyId  String
  status      BookingStatus @default(PENDING)
  scheduledAt DateTime
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([propertyId])
  @@index([scheduledAt])              // calendar / upcoming viewings view
  @@index([status, scheduledAt])      // "confirmed upcoming" query
}

// ─────────────────────────────────────────
// SERVICES
// ─────────────────────────────────────────

model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  iconUrl     String?
  imageUrl    String?
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────
// CONTENT
// ─────────────────────────────────────────

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  title     String
  bio       String?
  photoUrl  String?
  email     String?
  phone     String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Testimonial {
  id          String   @id @default(cuid())
  clientName  String
  clientTitle String?
  content     String
  rating      Int?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id        String              @id @default(cuid())
  channel   NotificationChannel
  recipient String
  subject   String?
  body      String
  status    NotificationStatus  @default(PENDING)
  sentAt    DateTime?
  error     String?
  metadata  Json?
  createdAt DateTime            @default(now())

  @@index([status, createdAt]) // retry queue for failed notifications
}

// ─────────────────────────────────────────
// ANALYTICS / ACTIVITY
// ─────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId, createdAt])  // "activity by user" admin view
  @@index([createdAt])
}

model PropertyView {
  id         String   @id @default(cuid())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  ipHash     String?
  userAgent  String?
  referrer   String?
  createdAt  DateTime @default(now())

  @@index([propertyId])
  @@index([propertyId, createdAt]) // "views over time" analytics per property
  @@index([createdAt])
}

// ─────────────────────────────────────────
// SITE SETTINGS
// ─────────────────────────────────────────

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}